# Anthropic API key — required for triage
ANTHROPIC_API_KEY=sk-ant-

# GitHub personal access token — required for GitHub PR comments
# Needs: repo scope (read access to PRs and comments)
GITHUB_TOKEN=ghp_

# GitLab personal access token — optional, only needed for GitLab MR comments
# Needs: api scope (read_api is enough)
GITLAB_TOKEN=glpat-

# GitLab instance URL — defaults to https://gitlab.com if not set
# Set this for self-hosted GitLab instances
# GITLAB_URL=https://gitlab.mycompany.com

# Override base URLs for testing against mock servers (set by make test-integration)
# REVIEWBRIDGE_GITHUB_BASE_URL=http://localhost:8080
# REVIEWBRIDGE_GITLAB_BASE_URL=http://localhost:8081
