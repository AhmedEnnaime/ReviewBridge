        "html_url": "https://github.com/owner/repo/pull/12"
      },
      {
        "number": 13,
        "title": "Add unit tests",
        "state": "open",
        "head": { "ref": "feature/issue-b" },
        "html_url": "https://github.com/owner/repo/pull/13"
      }
    ]
  }
}
